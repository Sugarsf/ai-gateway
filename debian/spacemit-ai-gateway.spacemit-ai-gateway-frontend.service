[Unit]
Description=SpacemiT AI Gateway Frontend (static console on :8326)
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/spacemit-ai-gateway/frontend
ExecStart=/usr/bin/python3 /opt/spacemit-ai-gateway/frontend/serve.py 8326 --bind ::
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
